# macOS
.DS_Store

# Editor / OS junk
.vscode/
.idea/
*.swp
*~

# Node (not used today, but prevents accidents)
node_modules/

# Python bytecode
__pycache__/
*.pyc

# Audio asset backups — kept locally for re-trimming only, not needed at runtime.
animal-race/assets/sounds/_originals/
animal-race/assets/sounds/_pre_normalize/

# Raw audio + intermediate manifest from tools/fetch_assets.py — runtime
# uses the trimmed files only.
tools/_raw_audio/

# API credentials — never commit.
tools/.freesound_token
.env
